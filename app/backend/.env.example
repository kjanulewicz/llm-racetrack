# Non-secret configuration — safe to commit the example file
TENANT_ID=
API_CLIENT_ID=
COSMOS_URL=
FRONTEND_ORIGIN=http://localhost:5173

# Optional: override org-default models config path
MODELS_CONFIG_PATH=config/models.config.json

# Set to true to bypass Entra ID auth for local development (no App Registration needed).
# Must remain false when ENVIRONMENT is anything other than "local".
DEV_MODE=false
